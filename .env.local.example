# --- GCP & Region ---
GOOGLE_CLOUD_PROJECT=${GCP_PROJECT_ID}
REGION=asia-northeast1

# --- Cloud SQL Proxy ---
CLOUDSQL_CONNECTION_NAME=${GCP_PROJECT_ID}:asia-northeast1:gm
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp_codex_dev.json

# --- Database (local dev fallback) ---
# Prefer Secret Manager via DATABASE_URL_SECRET_NAME in production.
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@cloudsql-proxy:5432/<DB_NAME>?sslmode=disable

# --- Firebase Admin ---
FIREBASE_CREDENTIALS_FILE=/app/secrets/firebase-adminsdk.json

# --- Pub/Sub (single-project, multi-env) ---
ENV=development
PUBSUB_TOPIC_ID=domain-events-dev
# Per-service subscription for local dev; adjust per service run
PUBSUB_SUBSCRIPTION_ID=offer-sub-dev

# --- Siterank SimilarWeb ---
SIMILARWEB_BASE_URL=https://data.similarweb.com/api/v1/data?domain=%s

# --- Batchopen Proxy (example) ---
PROXY_URL_US=https://api.iprocket.io/api?username=YOUR_USERNAME&password=YOUR_PASSWORD&cc=ROW&ips=1&type=-res-&proxyType=http&responseType=txt

# --- Google Ads API (fill if used) ---
GOOGLE_ADS_DEVELOPER_TOKEN=${GOOGLE_ADS_DEVELOPER_TOKEN}
GOOGLE_ADS_OAUTH_CLIENT_ID=${GOOGLE_OAUTH_CLIENT_ID}
GOOGLE_ADS_OAUTH_CLIENT_SECRET=${GOOGLE_OAUTH_CLIENT_SECRET}
GOOGLE_ADS_LOGIN_CUSTOMER_ID=5010618892
GOOGLE_ADS_REFRESH_TOKEN=
